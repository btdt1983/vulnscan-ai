# Environment for the vulnscan-ai systemd service (mode 0640, root-only).
#
# A scan-only scheduled run needs NOTHING here and sends no data off the host.
# Only set an API key if you add `--plan` to the service ExecStart so the AI
# can propose remediations in the report.

# Where the service stores findings and reports (matches /etc config).
VULNSCANAI_STATE_DIR=/var/lib/vulnscan-ai

# AI provider for `--plan` (claude is the default). Set the matching key:
#VULNSCANAI_PROVIDER=claude
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#GEMINI_API_KEY=
#MOONSHOT_API_KEY=

# Fully offline: use a local Ollama model — no key, no external calls.
#VULNSCANAI_PROVIDER=local
#OLLAMA_HOST=http://127.0.0.1:11434
#OLLAMA_MODEL=llama3.2:1b

# Optional: higher NVD rate limit during enrichment.
#NVD_API_KEY=
